    "@tailwindcss/cli": "^4.2.1",
    "@types/bun": "latest",
    "tailwindcss": "^4.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "hono": "^4.12.7"
  }
}
